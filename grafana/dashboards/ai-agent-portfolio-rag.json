{
  "uid": "ai-agent-portfolio-rag",
  "title": "AI Agent Portfolio Chat and RAG",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "15s",
  "tags": ["ai-agent-portfolio", "rag"],
  "panels": [
    {
      "type": "timeseries",
      "title": "AI /api/agent/ask QPS",
      "gridPos": {"x": 0, "y": 0, "w": 8, "h": 8},
      "targets": [{"refId": "A", "expr": "sum(rate(portfolio_agent_ask_total[1m])) by (status)"}]
    },
    {
      "type": "timeseries",
      "title": "RAG Retrieve Latency p95",
      "gridPos": {"x": 8, "y": 0, "w": 8, "h": 8},
      "targets": [{"refId": "A", "expr": "histogram_quantile(0.95, sum(rate(portfolio_rag_retrieve_duration_seconds_bucket[5m])) by (le))"}]
    },
    {
      "type": "timeseries",
      "title": "Empty Retrieval Rate",
      "gridPos": {"x": 16, "y": 0, "w": 8, "h": 8},
      "targets": [{"refId": "A", "expr": "sum(rate(portfolio_rag_retrieval_empty_total[5m])) / clamp_min(sum(rate(portfolio_rag_retrieve_total[5m])), 1)"}]
    },
    {
      "type": "timeseries",
      "title": "Retrieved Chunks",
      "gridPos": {"x": 0, "y": 8, "w": 12, "h": 8},
      "targets": [{"refId": "A", "expr": "histogram_quantile(0.95, sum(rate(portfolio_rag_retrieved_chunks_bucket[5m])) by (le))"}]
    },
    {
      "type": "timeseries",
      "title": "Answer Citation Count",
      "gridPos": {"x": 12, "y": 8, "w": 12, "h": 8},
      "targets": [{"refId": "A", "expr": "histogram_quantile(0.95, sum(rate(portfolio_rag_answer_citation_count_bucket[5m])) by (le))"}]
    }
  ]
}
